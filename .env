# ── API Keys ──────────────────────────────────────────────────────────────── #
GOOGLE_API_KEY=AIzaSyCqnSspwb6fXHRtYlw9vuBX2QYzTIU7ekk
GROQ_API_KEY=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
COHERE_API_KEY=KnDAjRJ5c1GCdyCmI3L2J0L2a5D7VajH3YOaIchp

# ── App Settings ──────────────────────────────────────────────────────────── #
APP_NAME=Multi-Model RAG API
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── LLM Routing ───────────────────────────────────────────────────────────── #
# Options: groq | gemini (Groq is now the default)
DEFAULT_LLM=groq
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Embeddings ────────────────────────────────────────────────────────────── #
EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_DIMENSION=3072

# ── ChromaDB ──────────────────────────────────────────────────────────────── #
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_documents

# ── Chunking ──────────────────────────────────────────────────────────────── #
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────────────────── #
TOP_K=5
HYBRID_ALPHA=0.7

# ── Storage Paths ─────────────────────────────────────────────────────────── #
DATA_DIR=./data
DOCUMENTS_DIR=./data/documents
IMAGES_DIR=./data/images
VIDEOS_DIR=./data/videos

# ── Celery / Redis ────────────────────────────────────────────────────────── #
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Logging ───────────────────────────────────────────────────────────────── #
LOG_LEVEL=INFO
LOG_FILE=app.log

# ── Evaluation ────────────────────────────────────────────────────────────── #
RAGAS_SAMPLE_SIZE=10
